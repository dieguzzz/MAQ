rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{userId} {
      // Permitir leer cualquier usuario para leaderboards (usuarios autenticados)
      allow read: if request.auth != null;
      // Solo permitir escribir/actualizar el propio perfil
      allow write: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // No permitir eliminar (usar función de Firebase Auth)
      
      // Subcolección de historial de puntos
      match /points_history/{transactionId} {
        // Solo el propio usuario puede leer su historial
        allow read: if request.auth != null && request.auth.uid == userId;
        // Solo el sistema puede escribir (usando serverTimestamp)
        // Permitir crear transacciones si el usuario está autenticado y es el dueño
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if false;
        allow delete: if false;
      }
    }
    
    // Stations collection
    match /stations/{stationId} {
      allow read: if true; // Todos pueden leer
      // Permitir crear para inicialización (no requiere autenticación si el documento no existe)
      // set() sin merge se trata como create si el documento no existe
      allow create: if !exists(/databases/$(database)/documents/stations/$(stationId));
      // Permitir actualizar solo si el documento existe y el usuario está autenticado
      allow update: if exists(/databases/$(database)/documents/stations/$(stationId)) && request.auth != null;
      // Permitir write (set) solo para crear nuevos documentos (inicialización)
      allow write: if !exists(/databases/$(database)/documents/stations/$(stationId));
      // No permitir eliminar
      allow delete: if false;
    }
    
    // Trains collection
    match /trains/{trainId} {
      allow read: if true; // Todos pueden leer
      // Permitir crear para inicialización (no requiere autenticación si el documento no existe)
      // set() sin merge se trata como create si el documento no existe
      allow create: if !exists(/databases/$(database)/documents/trains/$(trainId));
      // Permitir actualizar solo si el documento existe y el usuario está autenticado
      allow update: if exists(/databases/$(database)/documents/trains/$(trainId)) && request.auth != null;
      // Permitir write (set) solo para crear nuevos documentos (inicialización)
      allow write: if !exists(/databases/$(database)/documents/trains/$(trainId));
      // No permitir eliminar
      allow delete: if false;
    }
    
    // Reports collection (modelo simplificado)
    match /reports/{reportId} {
      allow read: if request.auth != null; // Usuarios autenticados pueden leer
      // Permitir crear si el usuario está autenticado y el userId coincide
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid;
      // Permitir actualizar si:
      // - El usuario es el dueño del reporte, O
      // - Solo se actualizan campos de confirmación/validación (cualquier usuario autenticado puede confirmar reportes de otros, pero no su propio reporte)
      allow update: if request.auth != null 
        && (resource.data.userId == request.auth.uid 
            || (request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['confirmations', 'confirmation_count', 'status', 'confidence', 'verification_status', 'validationStatus', 'validationPoints', 'totalPoints'])
                && resource.data.userId != request.auth.uid)); // No puede actualizar confirmaciones de su propio reporte
      allow delete: if false; // No permitir eliminar
      
      // Subcolección de validaciones ETA
      match /eta_validations/{userId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null 
          && request.auth.uid == userId;
        allow update: if false;
        allow delete: if false;
      }
      
      // Subcolección de confirmaciones
      match /confirmations/{userId} {
        allow read: if request.auth != null;
        // Permitir crear confirmación si:
        // - El usuario está autenticado
        // - El userId de la ruta coincide con el auth.uid
        // - No existe ya una confirmación
        // - El usuario NO es el dueño del reporte
        allow create: if request.auth != null 
          && request.auth.uid == userId
          && !exists(/databases/$(database)/documents/reports/$(reportId)/confirmations/$(userId))
          && get(/databases/$(database)/documents/reports/$(reportId)).data.userId != request.auth.uid;
        allow update: if false;
        allow delete: if false;
      }
    }
    
    // Routes collection
    match /routes/{routeId} {
      allow read: if true; // Todos pueden leer
      allow write: if false; // Solo system (Cloud Functions) puede escribir
    }
    
    // Learning Reports collection (para reportes de aprendizaje/enseñanza)
    match /learning_reports/{reportId} {
      allow read: if request.auth != null; // Usuarios autenticados pueden leer
      // Permitir crear si el usuario está autenticado y:
      // - El usuario_id coincide con el usuario autenticado (con prefijo simulated_ para admin)
      allow create: if request.auth != null 
        && (request.resource.data.usuario_id == request.auth.uid
            || request.resource.data.usuario_id == 'simulated_' + request.auth.uid);
      allow update: if false; // No permitir actualizar reportes
      allow delete: if false; // No permitir eliminar reportes
    }
    
    // Model Metrics collection (para métricas del modelo de ML)
    match /model_metrics/{metricId} {
      allow read: if request.auth != null; // Usuarios autenticados pueden leer
      allow write: if request.auth != null; // Usuarios autenticados pueden escribir (para admin/testing)
    }
    
    // Community Stats collection (para estadísticas del dashboard)
    match /community_stats/{statId} {
      allow read: if request.auth != null; // Usuarios autenticados pueden leer
      allow write: if false; // Solo Cloud Functions pueden escribir
    }
    
    // Train Time Reports collection (para reportes de tiempo de tren desde paneles)
    // La colección se crea automáticamente cuando se escribe el primer documento
    match /train_time_reports/{reportId} {
      allow read: if request.auth != null; // Usuarios autenticados pueden leer
      // Permitir crear si el usuario está autenticado y el userId coincide
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid;
      // Permitir actualizar solo el campo 'id' después de crear
      // resource existe porque estamos actualizando un documento que ya fue creado
      allow update: if request.auth != null 
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['id']);
      // Permitir eliminar solo si el usuario es el dueño
      allow delete: if request.auth != null 
        && resource.data.userId == request.auth.uid;
    }

    // ETA Groups (agregados del panel de tiempos) - SOLO backend (Cloud Functions)
    match /eta_groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if false;
      allow update: if false;
      allow delete: if false;

      match /arrivals/{userId} {
        allow read: if request.auth != null;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }

      match /presence/{userId} {
        allow read: if request.auth != null;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
    }
    
    // Debug Logs collection (para logs de depuración en modo test)
    // Permitir lectura sin autenticación para que la página web funcione
    // En producción, puedes restringir esto a usuarios autenticados
    match /debug_logs/{logId} {
      allow read: if true; // Permitir lectura pública (solo para debug)
      allow write: if request.auth != null; // Solo usuarios autenticados pueden escribir
    }
  }
}

