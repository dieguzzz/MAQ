rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile images - only owner can upload/delete, anyone authenticated can read
    match /profile_images/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource != null
        && request.resource.size < 5 * 1024 * 1024  // Max 5MB
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Report images - creator can upload, authenticated users can read
    match /report_images/{reportId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource != null
        && request.resource.size < 5 * 1024 * 1024  // Max 5MB
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
      allow delete: if false; // Only admin
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
